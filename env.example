# Database - use your MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/barkadia?retryWrites=true&w=majority
MONGODB_TEST_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/barkadia_test?retryWrites=true&w=majority

# JWT - use a long random string (32+ characters); required in production
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
JWT_EXPIRE=7d

# Server
PORT=8000
NODE_ENV=development

# CORS
FRONTEND_URL=http://localhost:3000

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads
